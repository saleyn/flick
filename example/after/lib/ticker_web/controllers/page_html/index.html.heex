<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Ticker</title>
  <!-- Added by mix flick.install: loads window.Flick before app.js -->
  <script src={~p"/assets/js/flick.min.js"}></script>
  <script defer src="/assets/js/app.js"></script>
</head>
<body>
  <h1>Live Price Feed</h1>
  <table id="ticker">
    <thead>
      <tr><th>Symbol</th><th>Open</th><th>High</th><th>Low</th><th>Close</th><th>Volume</th></tr>
    </thead>
    <tbody id="rows"></tbody>
  </table>
</body>
</html>
